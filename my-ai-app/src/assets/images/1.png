px solid rgb(255, 255, 255); background: rgb(5, 233, 245); border-radius: 5=
0%; box-shadow: rgba(0, 0, 0, 0.15) 0px 1px 12px 0px; }

.ltr .obj_det > .core { transform: translate(-50%, -50%); }

