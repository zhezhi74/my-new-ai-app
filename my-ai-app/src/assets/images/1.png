-serif; text-overflow: ellipsis; white-space: nowrap; margin: 0px 10px; col=
or: rgb(118, 118, 118); }

@keyframes wave {=20
  0% { transform: rotateX(0deg); }
  100% { transform: rotateX(40deg); }
}

.b_mic_wave { animation: 0.5s ease 0s infinite alternate none running wave;=
