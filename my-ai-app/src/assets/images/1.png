@media (max-width: 1440px) {
  #id_n { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; m=
ax-width: 90px; display: inline-block; }
}

#id_rh_w { position: relative; }

#rh_rwm { display: inline-block; --rw-red-dot-color: #c80000; }

#rh_rwm.rw-dark { --rw-red-dot-color: #ff8080; }

#rh_rwm.maps { display: contents; }

#rh_rwm.maps:not(.rw-dark) { --rw-medal-color: #106ebe; }

#rh_rwm.hp { --rw-medal-color: #fff; --rw-font-color: #fff; display: inline=
-block; margin: 2px 6px 0px; height: 42px; }

.gih_pink #rh_rwm { --rw-medal-color: #e63887; --rw-font-color: #fff; }

#rh_rwm.serp { margin-left: 16px; height: 50px; }

#rh_rwm.hide { display: none; }

#id_rh_w.tooltip::before { position: absolute; height: 10px; width: 10px; t=
op: 50px; left: 50%; right: unset; background-color: rgb(102, 102, 102); tr=
ansform: translate3d(-50%, 50%, 0px) rotate(45deg); content: ""; }

#id_rh_w.tooltip::after { position: absolute; font-size: 0.8125rem; line-he=
ight: 150%; white-space: pre; top: 58px; left: 50%; right: unset; transform=
: translateX(-50%); content: attr(aria-label) ""; color: rgb(255, 255, 255)=
; border-radius: 6px; padding: 10px 15px; background-color: rgb(102, 102, 1=
02); }

#id_rh_w.tooltip:dir(rtl)::before { transform: translate3d(50%, 50%, 0px) r=
otate(45deg); }

#id_rh_w.tooltip:dir(rtl)::after { transform: translateX(50%); }

#id_rh_w.tooltip::before, #id_rh_w.tooltip::after { z-index: 7; pointer-eve=
nts: none; transition: 0.1s; opacity: 0; display: none; }

#id_rh_w.tooltip:hover::before, #id_rh_w.tooltip:hover::after, #id_rh_w.too=
ltip:focus::before, #id_rh_w.tooltip:focus::after { opacity: 1; display: bl=
ock; }

#rh_rwm:hover::before, #rh_rwm:hover::after, #rh_rwm:focus::before, #rh_rwm=
:focus::after { opacity: 0; display: none; }

@media (max-width: 1274.9px) {
  body:not(.b_norr) #rh_rwm.serp { margin-right: 12px; margin-left: 8px; }
  body.b_norr #rh_rwm.serp { margin-right: 0px; margin-left: 0px; }
  body.b_norr #id_rh_w { margin: 0px; }
}

#rh_rwm.spotlight { --rw-medal-color: #fff; --rw-font-color: #fff; }

#rh_rwm.serp.liftsearchcap_claiamble_pts.medallion circle, #rh_rwm.hp.lifts=
earchcap_claiamble_pts.medallion circle { stroke: var(--rw-color,var(--rw-r=
ed-dot-color)); }

#rh_rwm.serp.unc.medallion.red-balance { --rw-font-color: var(--rw-red-dot-=
color,#c80000); }

#rh_rwm.serp.medallion.kumo_rewards > div { padding: initial; }

#rh_rwm.serp.medallion.kumo_rewards div.medal { height: 36px; margin-inline=
-start: 4px; align-items: center; padding: 0px 6px; }

#rh_rwm.serp.medallion.kumo_rewards > div > * { padding: initial; }

#rh_rwm.serp.medallion.kumo_rewards svg.medal-circled { width: 24px; height=
: 24px; fill: rgb(36, 36, 36); }

#rh_rwm.serp.medallion.rw-dark.kumo_rewards svg.medal-circled { fill: rgb(2=
55, 255, 255); }

#rh_rwm.serp.medallion.kumo_rewards .points-container { color: rgba(0, 0, 0=
, 0.75); line-height: var(--Font-Body-2-Line-height,22px); font-size: var(-=
-Font-Body-2-Font-size,14px); }
